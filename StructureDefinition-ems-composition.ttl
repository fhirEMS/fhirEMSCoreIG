       fhir:ContactPoint.value [ fhir:value "https://github.com/fhirEMS/fhirEMSCoreIG" ]
     ]
  ] ;
  fhir:StructureDefinition.description [ fhir:value "Represents an EMS Patient Care Report (PCR) as a FHIR Composition.\nThis is the root document that ties together all sections of an EMS\ncall. Based on NEMSIS eRecord and overall PCR structure\n(Version 3.5.1.251001CP2).\n\nSection codes: Standard LOINC codes are used where a clear analog\nexists. NEMSIS-specific section codes (nemsis-codes#section-*) are\nused for EMS-only sections without a well-matched LOINC code.\n\nMandatory NEMSIS sections (1..1): eResponse, eTimes, ePatient,\neScene, eSituation, eDisposition.\nOptional NEMSIS sections (0..1 or 0..*): eHistory, eVitals,\neProcedures, eMedications, eExam, eAirway, eArrest, eNarrative."] ;
  fhir:StructureDefinition.jurisdiction [
     fhir:index 0 ;
     fhir:CodeableConcept.coding [
       fhir:index 0 ;
       fhir:Coding.system [ fhir:value "urn:iso:std:iso:3166" ] ;
       fhir:Coding.code [ fhir:value "US" ] ;
       fhir:Coding.display [ fhir:value "United States of America" ]
     ]
  ] ;
  fhir:StructureDefinition.fhirVersion [ fhir:value "4.0.1"] ;
  fhir:StructureDefinition.mapping [
     fhir:index 0 ;
     fhir:StructureDefinition.mapping.identity [ fhir:value "workflow" ] ;
     fhir:StructureDefinition.mapping.uri [ fhir:value "http://hl7.org/fhir/workflow" ] ;
     fhir:StructureDefinition.mapping.name [ fhir:value "Workflow Pattern" ]
  ], [
