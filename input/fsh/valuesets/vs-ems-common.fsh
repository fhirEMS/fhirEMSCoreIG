* $nemsis-cs#3101005 "Hearing Impaired"
* $nemsis-cs#3101007 "Language"
* $nemsis-cs#3101009 "None Noted"
* $nemsis-cs#3101011 "Obesity"
* $nemsis-cs#3101013 "Physical Barrier (Unable to Access Patient)"
* $nemsis-cs#3101015 "Physically Impaired"
* $nemsis-cs#3101017 "Physically Restrained"
* $nemsis-cs#3101019 "Psychologically Impaired"
* $nemsis-cs#3101021 "Sight Impaired"
* $nemsis-cs#3101023 "Speech Impaired"
* $nemsis-cs#3101025 "Unattended or Unsupervised (including minors)"
