// ============================================================
// EMS Common ValueSets
// Cross-cutting: NV, PN, certification, barrier, situation, protocols
// ============================================================

// ── EMSNotValueVS ─────────────────────────────────────────────
// NEMSIS NV pattern — used across 269 of 657 elements
ValueSet: EMSNotValueVS
Id: vs-ems-not-value
Title: "NEMSIS Not Value (NV)"
Description: "NEMSIS Not Value codes used when a data element is Not Applicable, Not Recorded, or Not Reporting."
* ^url = "http://hl7.org/fhir/us/emscore/ValueSet/vs-ems-not-value"
* ^status = #active
* $nemsis-nv#NV.NotApplicable   "Not Applicable"
* $nemsis-nv#NV.NotRecorded     "Not Recorded"
* $nemsis-nv#NV.NotReporting    "Not Reporting"

// ── EMSPertinentNegativeVS ────────────────────────────────────
// NEMSIS PN pattern — used across 70 of 657 elements
ValueSet: EMSPertinentNegativeVS
Id: vs-ems-pertinent-negative
Title: "NEMSIS Pertinent Negative (PN)"
Description: "NEMSIS Pertinent Negative codes indicating a clinically significant documented absence."
* ^url = "http://hl7.org/fhir/us/emscore/ValueSet/vs-ems-pertinent-negative"
* ^status = #active
* $nemsis-pn#PN.Approximate              "Approximate"
* $nemsis-pn#PN.ContraindicationNoted    "Contraindication Noted"
* $nemsis-pn#PN.DeniedByOrder            "Denied By Order"
* $nemsis-pn#PN.ExamFindingNotPresent    "Exam Finding Not Present"
* $nemsis-pn#PN.MedicationAllergy        "Medication Allergy"
* $nemsis-pn#PN.MedicationAlreadyTaken   "Medication Already Taken"
* $nemsis-pn#PN.NoKnownDrugAllergy       "No Known Drug Allergy"
* $nemsis-pn#PN.NoneReported             "None Reported"
* $nemsis-pn#PN.NotImmunized             "Not Immunized"
* $nemsis-pn#PN.OrderCriteriaNotMet      "Order Criteria Not Met"
* $nemsis-pn#PN.Refused                  "Refused"
* $nemsis-pn#PN.SymptomNotPresent        "Symptom Not Present"
* $nemsis-pn#PN.UnableToComplete         "Unable To Complete"
* $nemsis-pn#PN.Unresponsive             "Unresponsive"

// ── EMSCertificationLevelVS ───────────────────────────────────
// NEMSIS: eCrew.02 - Crew Member Level (Mandatory/National)
ValueSet: EMSCertificationLevelVS
Id: vs-ems-certification-level
