# ── Node / npm ──────────────────────────────────────────────────────────────
node_modules/
package-lock.json

# ── SUSHI generated output ──────────────────────────────────────────────────
# Regenerated by `sushi .` — do not commit
fsh-generated/

# ── IG Publisher output ─────────────────────────────────────────────────────
# Regenerated by `java -jar input-cache/publisher.jar -ig .` — do not commit
output/
temp/
template/

# ── IG Publisher tool files ─────────────────────────────────────────────────
# Large binary downloaded by _updatePublisher.sh
input-cache/publisher.jar
input-cache/validator.jar
# Downloaded metadata files
input-cache/workgroups.xml
# Terminology cache — rebuilt automatically on first run; not needed in source control
input-cache/txcache/

# ── Local JDK (downloaded by IG Publisher setup) ────────────────────────────
.jdk/

# ── macOS system files ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# ── Claude Code project files ────────────────────────────────────────────────
# Contains session memory; not part of the IG source
.claude/
