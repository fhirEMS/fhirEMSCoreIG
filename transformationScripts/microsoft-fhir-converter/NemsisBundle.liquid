{% comment -%}
Root template: NEMSIS EMSDataSet (canonical JSON, see transforms/tools) -> FHIR
transaction Bundle of fhirEMSCore (fhirems.emscore) resources.
Input variable: msg  (the canonical JSON document)
Deterministic ids are derived from eRecord.01 via the generate_uuid filter.
{%- endcomment -%}
{
  "resourceType": "Bundle",
  "type": "transaction",
  "entry": [
    {% for header in msg.EMSDataSet.Header -%}
    {% for pcr in header.PatientCareReport -%}
    {% assign base = pcr.eRecord['eRecord.01'].value -%}
    {% capture patientId %}{{ base | append: '-patient' | generate_uuid }}{% endcapture -%}
    {% capture encounterId %}{{ base | append: '-encounter' | generate_uuid }}{% endcapture -%}
    {% capture sceneId %}{{ base | append: '-scene' | generate_uuid }}{% endcapture -%}
    {% capture orgId %}{{ base | append: '-agency' | generate_uuid }}{% endcapture -%}
    {% capture conditionId %}{{ base | append: '-condition' | generate_uuid }}{% endcapture -%}
    {% include 'Resource_Composition' pcr: pcr, base: base, patientId: patientId, encounterId: encounterId, sceneId: sceneId, orgId: orgId, conditionId: conditionId -%}
    {% assign ag = pcr.eResponse['eResponse.AgencyGroup'] | first -%}
    {
      "fullUrl": "urn:uuid:{{ orgId }}",
      "resource": {
        "resourceType": "Organization",
        "id": "{{ orgId }}",
        "meta": { "profile": ["https://fhirems.github.io/fhirEMSCoreIG/StructureDefinition/ems-organization", "http://hl7.org/fhir/us/core/StructureDefinition/us-core-organization"] },
        "identifier": [ { "system": "urn:oid:2.25.219926138944530828037824748808947630693", "value": "{{ ag['eResponse.01'].value | default: base }}" } ],
        "active": true,
        "name": "{{ ag['eResponse.02'].value | default: 'EMS Agency' }}"
      },
      "request": { "method": "POST", "url": "Organization" }
    },
    {
      "fullUrl": "urn:uuid:{{ patientId }}",
      "resource": {% include 'Resource_Patient' pcr: pcr, patientId: patientId %},
      "request": { "method": "POST", "url": "Patient" }
    },
    {
      "fullUrl": "urn:uuid:{{ encounterId }}",
      "resource": {% include 'Resource_Encounter' pcr: pcr, patientId: patientId, encounterId: encounterId, orgId: orgId %},
      "request": { "method": "POST", "url": "Encounter" }
    },
    {% if pcr.eScene -%}
    {
      "fullUrl": "urn:uuid:{{ sceneId }}",
      "resource": {% include 'Resource_LocationScene' pcr: pcr, resId: sceneId %},
      "request": { "method": "POST", "url": "Location" }
    },
    {% endif -%}
    {% if pcr.eSituation['eSituation.11'].value -%}
    {
      "fullUrl": "urn:uuid:{{ conditionId }}",
      "resource": {% include 'Resource_Condition' pcr: pcr, patientId: patientId, encounterId: encounterId, resId: conditionId %},
      "request": { "method": "POST", "url": "Condition" }
    },
    {% endif -%}
    {% for crew in pcr.eCrew['eCrew.CrewGroup'] -%}
    {% include 'Resource_Crew' crew: crew, base: base, crewIndex: forloop.index, orgId: orgId -%}
    {% endfor -%}
    {% for vg in pcr.eVitals['eVitals.VitalGroup'] -%}
    {% assign fallbackWhen = pcr.eTimes['eTimes.07'].value | default: pcr.eTimes['eTimes.06'].value | default: pcr.eTimes['eTimes.03'].value -%}
    {% include 'Resource_ObservationVitals' vg: vg, base: base, vgIndex: forloop.index, patientId: patientId, encounterId: encounterId, fallbackWhen: fallbackWhen -%}
    {% endfor -%}
    {% for prc in pcr.eProcedures['eProcedures.ProcedureGroup'] -%}
    {% if prc['eProcedures.03'].value -%}
    {% capture procId %}{{ base | append: '-procedure-' | append: forloop.index | generate_uuid }}{% endcapture -%}
    {
      "fullUrl": "urn:uuid:{{ procId }}",
      "resource": {% include 'Resource_Procedure' prc: prc, patientId: patientId, encounterId: encounterId, resId: procId %},
      "request": { "method": "POST", "url": "Procedure" }
    },
    {% endif -%}
    {% endfor -%}
    {% for med in pcr.eMedications['eMedications.MedicationGroup'] -%}
    {% if med['eMedications.03'].value -%}
    {% capture medId %}{{ base | append: '-medication-' | append: forloop.index | generate_uuid }}{% endcapture -%}
    {
      "fullUrl": "urn:uuid:{{ medId }}",
      "resource": {% include 'Resource_MedicationAdministration' med: med, patientId: patientId, encounterId: encounterId, resId: medId %},
      "request": { "method": "POST", "url": "MedicationAdministration" }
    },
    {% endif -%}
    {% endfor -%}
    {% include 'Resource_ConditionArrest' pcr: pcr, base: base, patientId: patientId, encounterId: encounterId -%}
    {% include 'Resource_ConditionInjury' pcr: pcr, base: base, patientId: patientId, encounterId: encounterId -%}
    {% include 'Resource_History' pcr: pcr, base: base, patientId: patientId, encounterId: encounterId -%}
    {% for ag in pcr.eExam['eExam.AssessmentGroup'] -%}
    {% assign examWhen = ag['eExam.03'].value -%}
    {% include 'Resource_ObservationExamRegion' findings: ag['eExam.04'], regionLabel: 'Skin Assessment', regionSlug: 'skin', loincCode: '8709-8', locationLeaf: nil, base: base, patientId: patientId, encounterId: encounterId, examWhen: examWhen, agIndex: forloop.index -%}
    {% include 'Resource_ObservationExamRegion' findings: ag['eExam.05'], regionLabel: 'Head Assessment', regionSlug: 'head', loincCode: '11396-1', locationLeaf: nil, base: base, patientId: patientId, encounterId: encounterId, examWhen: examWhen, agIndex: forloop.index -%}
    {% include 'Resource_ObservationExamRegion' findings: ag['eExam.06'], regionLabel: 'Face Assessment', regionSlug: 'face', loincCode: '', locationLeaf: nil, base: base, patientId: patientId, encounterId: encounterId, examWhen: examWhen, agIndex: forloop.index -%}
    {% include 'Resource_ObservationExamRegion' findings: ag['eExam.07'], regionLabel: 'Neck Assessment', regionSlug: 'neck', loincCode: '', locationLeaf: nil, base: base, patientId: patientId, encounterId: encounterId, examWhen: examWhen, agIndex: forloop.index -%}
    {% include 'Resource_ObservationExamRegion' findings: ag['eExam.09'], regionLabel: 'Heart Assessment', regionSlug: 'heart', loincCode: '', locationLeaf: nil, base: base, patientId: patientId, encounterId: encounterId, examWhen: examWhen, agIndex: forloop.index -%}
    {% include 'Resource_ObservationExamRegion' findings: ag['eExam.11'], regionLabel: 'Abdomen Assessment', regionSlug: 'abdomen', loincCode: '', locationLeaf: ag['eExam.10'], base: base, patientId: patientId, encounterId: encounterId, examWhen: examWhen, agIndex: forloop.index -%}
    {% include 'Resource_ObservationExamRegion' findings: ag['eExam.12'], regionLabel: 'Pelvis/Genitourinary Assessment', regionSlug: 'pelvis', loincCode: '', locationLeaf: nil, base: base, patientId: patientId, encounterId: encounterId, examWhen: examWhen, agIndex: forloop.index -%}
    {% include 'Resource_ObservationExamRegion' findings: ag['eExam.14'], regionLabel: 'Back and Spine Assessment', regionSlug: 'back', loincCode: '', locationLeaf: ag['eExam.13'], base: base, patientId: patientId, encounterId: encounterId, examWhen: examWhen, agIndex: forloop.index -%}
    {% include 'Resource_ObservationExamRegion' findings: ag['eExam.16'], regionLabel: 'Extremities Assessment', regionSlug: 'extremities', loincCode: '', locationLeaf: ag['eExam.15'], base: base, patientId: patientId, encounterId: encounterId, examWhen: examWhen, agIndex: forloop.index -%}
    {% include 'Resource_ObservationExamRegion' findings: ag['eExam.18'], regionLabel: 'Eye Assessment', regionSlug: 'eye', loincCode: '', locationLeaf: ag['eExam.17'], base: base, patientId: patientId, encounterId: encounterId, examWhen: examWhen, agIndex: forloop.index -%}
    {% include 'Resource_ObservationExamRegion' findings: ag['eExam.19'], regionLabel: 'Mental Status Assessment', regionSlug: 'mental', loincCode: '', locationLeaf: nil, base: base, patientId: patientId, encounterId: encounterId, examWhen: examWhen, agIndex: forloop.index -%}
    {% include 'Resource_ObservationExamRegion' findings: ag['eExam.20'], regionLabel: 'Neurological Assessment', regionSlug: 'neuro', loincCode: '10197-4', locationLeaf: nil, base: base, patientId: patientId, encounterId: encounterId, examWhen: examWhen, agIndex: forloop.index -%}
    {% include 'Resource_ObservationExamRegion' findings: ag['eExam.23'], regionLabel: 'Lung Assessment', regionSlug: 'lung', loincCode: '29546-5', locationLeaf: ag['eExam.22'], base: base, patientId: patientId, encounterId: encounterId, examWhen: examWhen, agIndex: forloop.index -%}
    {% include 'Resource_ObservationExamRegion' findings: ag['eExam.25'], regionLabel: 'Chest Assessment', regionSlug: 'chest', loincCode: '', locationLeaf: ag['eExam.24'], base: base, patientId: patientId, encounterId: encounterId, examWhen: examWhen, agIndex: forloop.index -%}
    {% endfor -%}
    {% for lg in pcr.eLabs['eLabs.LabGroup'] -%}
    {% include 'Resource_ObservationLabs' lg: lg, lgIndex: forloop.index, base: base, patientId: patientId, encounterId: encounterId -%}
    {% endfor -%}
    {% endfor -%}
    {% endfor -%}
  ]
}
