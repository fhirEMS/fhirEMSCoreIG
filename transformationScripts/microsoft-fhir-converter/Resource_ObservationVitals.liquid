{% comment -%} One eVitals.VitalGroup -> Observation resources (NDR-007):
BP panel (eVitals.06/.07 -> ems-observation-bp, LOINC 85354-9 with 8480-6 /
8462-4 components) and simple vitals (HR .10, SpO2 .12, RR .14 ->
ems-observation-vitalsigns). Each entry renders complete with its own
fullUrl/request; emitted inside the Bundle entry array. Simple vitals are
unrolled explicitly — DotLiquid does not support dynamic bracket keys. {%- endcomment -%}
{% assign IGX = 'https://fhirems.github.io/fhirEMSCoreIG/StructureDefinition' -%}
{% assign when = vg['eVitals.01'].value | default: fallbackWhen -%}
{% if vg['eVitals.06'].value -%}
{
  {% capture obsId %}{{ base | append: '-vg' | append: vgIndex | append: '-bp' | generate_uuid }}{% endcapture -%}
  "fullUrl": "urn:uuid:{{ obsId }}",
  "resource": {
    "resourceType": "Observation",
    "id": "{{ obsId }}",
    "meta": { "profile": ["{{ IGX }}/ems-observation-bp", "http://hl7.org/fhir/us/core/StructureDefinition/us-core-blood-pressure"] },
    "status": "final",
    "category": [ { "coding": [ { "system": "http://terminology.hl7.org/CodeSystem/observation-category", "code": "vital-signs", "display": "Vital Signs" } ] } ],
    "code": { "coding": [ { "system": "http://loinc.org", "code": "85354-9", "display": "Blood pressure panel with all children optional" } ] },
    "subject": { "reference": "urn:uuid:{{ patientId }}" },
    "encounter": { "reference": "urn:uuid:{{ encounterId }}" },
    {% if when %}"effectiveDateTime": "{{ when }}",{% else %}"_effectiveDateTime": { "extension": [ { "url": "http://hl7.org/fhir/StructureDefinition/data-absent-reason", "valueCode": "unknown" } ] },{% endif %}
    "component": [
      { "code": { "coding": [ { "system": "http://loinc.org", "code": "8480-6", "display": "Systolic blood pressure" } ] },
        "valueQuantity": { "value": {{ vg['eVitals.06'].value }}, "unit": "mmHg", "system": "http://unitsofmeasure.org", "code": "mm[Hg]" } },
      {% if vg['eVitals.07'].value -%}
      { "code": { "coding": [ { "system": "http://loinc.org", "code": "8462-4", "display": "Diastolic blood pressure" } ] },
        "valueQuantity": { "value": {{ vg['eVitals.07'].value }}, "unit": "mmHg", "system": "http://unitsofmeasure.org", "code": "mm[Hg]" } },
      {% endif -%}
    ]
  },
  "request": { "method": "POST", "url": "Observation" }
},
{% endif -%}
{% if vg['eVitals.10'].value -%}
{
  {% capture obsId %}{{ base | append: '-vg' | append: vgIndex | append: '-hr' | generate_uuid }}{% endcapture -%}
  "fullUrl": "urn:uuid:{{ obsId }}",
  "resource": {
    "resourceType": "Observation",
    "id": "{{ obsId }}",
    "meta": { "profile": ["{{ IGX }}/ems-observation-vitalsigns", "http://hl7.org/fhir/us/core/StructureDefinition/us-core-heart-rate"] },
    "status": "final",
    "category": [ { "coding": [ { "system": "http://terminology.hl7.org/CodeSystem/observation-category", "code": "vital-signs", "display": "Vital Signs" } ] } ],
    "code": { "coding": [ { "system": "http://loinc.org", "code": "8867-4", "display": "Heart rate" } ] },
    "subject": { "reference": "urn:uuid:{{ patientId }}" },
    "encounter": { "reference": "urn:uuid:{{ encounterId }}" },
    {% if when %}"effectiveDateTime": "{{ when }}",{% else %}"_effectiveDateTime": { "extension": [ { "url": "http://hl7.org/fhir/StructureDefinition/data-absent-reason", "valueCode": "unknown" } ] },{% endif %}
    "valueQuantity": { "value": {{ vg['eVitals.10'].value }}, "unit": "/min", "system": "http://unitsofmeasure.org", "code": "/min" }
  },
  "request": { "method": "POST", "url": "Observation" }
},
{% endif -%}
