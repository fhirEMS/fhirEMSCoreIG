{% comment -%} eArrest -> EMSConditionArrest (NDR-009). Emitted only when
eArrest.01 indicates an arrest occurred (3001003/3001005). Fixed SNOMED
410429000; all arrest detail in ext-ems-arrest-context. Self-contained
bundle entry. {%- endcomment -%}
{% assign IGX = 'https://fhirems.github.io/fhirEMSCoreIG/StructureDefinition' -%}
{% assign ACS = 'https://fhirems.github.io/fhirEMSCoreIG/CodeSystem/cs-nemsis-arrest' -%}
{% assign ar = pcr.eArrest -%}
{% assign a1 = ar['eArrest.01'].value -%}
{% if a1 == '3001003' or a1 == '3001005' -%}
{% capture arrestId %}{{ base | append: '-arrest' | generate_uuid }}{% endcapture -%}
{
  "fullUrl": "urn:uuid:{{ arrestId }}",
  "resource": {
    "resourceType": "Condition",
    "id": "{{ arrestId }}",
    "meta": { "profile": ["{{ IGX }}/ems-condition-arrest", "http://hl7.org/fhir/us/core/StructureDefinition/us-core-condition-encounter-diagnosis"] },
    "clinicalStatus": { "coding": [ { "system": "http://terminology.hl7.org/CodeSystem/condition-clinical", "code": "active" } ] },
    "verificationStatus": { "coding": [ { "system": "http://terminology.hl7.org/CodeSystem/condition-ver-status", "code": "confirmed" } ] },
    "category": [ { "coding": [ { "system": "http://terminology.hl7.org/CodeSystem/condition-category", "code": "encounter-diagnosis", "display": "Encounter Diagnosis" } ] } ],
    "code": { "coding": [ { "system": "http://snomed.info/sct", "code": "410429000", "display": "Cardiac arrest" } ] },
    "subject": { "reference": "urn:uuid:{{ patientId }}" },
    "encounter": { "reference": "urn:uuid:{{ encounterId }}" },
    {% if ar['eArrest.14'].value %}"onsetDateTime": "{{ ar['eArrest.14'].value }}",{% endif %}
    "extension": [
      { "url": "{{ IGX }}/ext-ems-arrest-context",
        "extension": [
          { "url": "cardiacArrest", "valueCodeableConcept": { "coding": [ { "system": "{{ ACS }}", "code": "{{ a1 }}" } ] } },
          {% if ar['eArrest.02'].value %}{ "url": "etiology", "valueCodeableConcept": { "coding": [ { "system": "{{ ACS }}", "code": "{{ ar['eArrest.02'].value }}" } ] } },{% endif %}
          {% for x in ar['eArrest.03'] %}{% if x.value %}{ "url": "resuscitationBy", "valueCodeableConcept": { "coding": [ { "system": "{{ ACS }}", "code": "{{ x.value }}" } ] } },{% endif %}{% endfor %}
          {% for x in ar['eArrest.04'] %}{% if x.value %}{ "url": "witnessedBy", "valueCodeableConcept": { "coding": [ { "system": "{{ ACS }}", "code": "{{ x.value }}" } ] } },{% endif %}{% endfor %}
          {% if ar['eArrest.07'].value %}{ "url": "aedUsePrior", "valueCodeableConcept": { "coding": [ { "system": "{{ ACS }}", "code": "{{ ar['eArrest.07'].value }}" } ] } },{% endif %}
          {% for x in ar['eArrest.09'] %}{% if x.value %}{ "url": "cprType", "valueCodeableConcept": { "coding": [ { "system": "{{ ACS }}", "code": "{{ x.value }}" } ] } },{% endif %}{% endfor %}
          {% if ar['eArrest.11'].value %}{ "url": "firstRhythm", "valueCodeableConcept": { "coding": [ { "system": "{{ ACS }}", "code": "{{ ar['eArrest.11'].value }}" } ] } },{% endif %}
          {% for x in ar['eArrest.12'] %}{% if x.value %}{ "url": "rosc", "valueCodeableConcept": { "coding": [ { "system": "{{ ACS }}", "code": "{{ x.value }}" } ] } },{% endif %}{% endfor %}
          {% if ar['eArrest.14'].value %}{ "url": "arrestDateTime", "valueDateTime": "{{ ar['eArrest.14'].value }}" },{% endif %}
          {% for x in ar['eArrest.16'] %}{% if x.value %}{ "url": "cprDiscontinuedReason", "valueCodeableConcept": { "coding": [ { "system": "{{ ACS }}", "code": "{{ x.value }}" } ] } },{% endif %}{% endfor %}
          {% for x in ar['eArrest.17'] %}{% if x.value %}{ "url": "rhythmAtDestination", "valueCodeableConcept": { "coding": [ { "system": "{{ ACS }}", "code": "{{ x.value }}" } ] } },{% endif %}{% endfor %}
          {% if ar['eArrest.18'].value %}{ "url": "endOfArrestEvent", "valueCodeableConcept": { "coding": [ { "system": "{{ ACS }}", "code": "{{ ar['eArrest.18'].value }}" } ] } },{% endif %}
          {% if ar['eArrest.20'].value %}{ "url": "whoFirstCPR", "valueCodeableConcept": { "coding": [ { "system": "{{ ACS }}", "code": "{{ ar['eArrest.20'].value }}" } ] } },{% endif %}
          {% if ar['eArrest.21'].value %}{ "url": "whoFirstAED", "valueCodeableConcept": { "coding": [ { "system": "{{ ACS }}", "code": "{{ ar['eArrest.21'].value }}" } ] } },{% endif %}
          {% if ar['eArrest.22'].value %}{ "url": "whoFirstDefibrillated", "valueCodeableConcept": { "coding": [ { "system": "{{ ACS }}", "code": "{{ ar['eArrest.22'].value }}" } ] } },{% endif %}
        ] }
    ]
  },
  "request": { "method": "POST", "url": "Condition" }
},
{% endif -%}
